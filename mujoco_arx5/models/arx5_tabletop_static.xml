<mujoco model="arx5_robosuite_tabletop_static">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.008333333333333333" gravity="0 0 -9.81"/>

  <custom>
    <!-- Isaac ARX5 deploy/data collection reference pose, kept here until the robot phase imports ARX5. -->
    <numeric name="arx5_base_pose_reference" data="-0.535 -0.21 0.8 1.0 0.0 0.0 0.0"/>
    <numeric name="workspace_x_range" data="-0.4 -0.2"/>
    <numeric name="workspace_y_range" data="-0.3 -0.1"/>
    <numeric name="robot_xy_jitter_m" data="0.02"/>
    <numeric name="control_dt_reference" data="0.1"/>
  </custom>

  <asset>
    <texture name="floor_grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.72 0.72 0.70" rgb2="0.62 0.62 0.60"/>
    <material name="floor_mat" texture="floor_grid" texrepeat="3 3" reflectance="0.05"/>
    <material name="table_silver" rgba="0.75 0.75 0.72 1" reflectance="0.15" shininess="0.35" specular="0.5"/>
    <material name="table_legs_metal" rgba="0.55 0.55 0.55 1" reflectance="0.3" shininess="0.6" specular="0.4"/>
    <material name="curtain_mat" rgba="0.72 0.72 0.70 1"/>
    <material name="receptive_cube_red" rgba="1.0 0.0 0.0 1.0"/>
    <material name="insertive_cube_green" rgba="0.0 1.0 0.0 1.0"/>
    <material name="workspace_marker_mat" rgba="0.0 0.2 1.0 0.65"/>
  </asset>

  <worldbody>
    <light name="key_light" pos="-0.3 -0.4 3.0" dir="0.2 0.2 -1.0" directional="true" diffuse="0.8 0.8 0.8"/>
    <light name="fill_light" pos="0.5 0.6 2.0" diffuse="0.35 0.35 0.35"/>
    <geom name="floor" type="plane" size="2.0 2.0 0.01" material="floor_mat" pos="0 0 0"/>

    <!-- Robosuite table-only MJCF port. Isaac places the converted USD at z=0.799375; the source MJCF table body is z=0.775 with a 0.025 half-height top, so table_top is z=0.800. -->
    <body name="table" pos="0 0 0.775">
      <geom name="table_collision" pos="0 0 0" size="0.6 0.45 0.025" type="box" group="0" friction="1 0.005 0.0001"/>
      <geom name="table_visual" pos="0 0 0" size="0.6 0.45 0.025" type="box" conaffinity="0" contype="0" group="1" material="table_silver"/>
      <site name="table_top" pos="0 0 0.025" size="0.001 0.001 0.001" rgba="0 0 0 0"/>

      <geom name="table_leg1_visual" pos="0.5 0.35 -0.3875" size="0.025 0.3875" type="cylinder" conaffinity="0" contype="0" group="1" material="table_legs_metal"/>
      <geom name="table_leg2_visual" pos="-0.5 0.35 -0.3875" size="0.025 0.3875" type="cylinder" conaffinity="0" contype="0" group="1" material="table_legs_metal"/>
      <geom name="table_leg3_visual" pos="-0.5 -0.35 -0.3875" size="0.025 0.3875" type="cylinder" conaffinity="0" contype="0" group="1" material="table_legs_metal"/>
      <geom name="table_leg4_visual" pos="0.5 -0.35 -0.3875" size="0.025 0.3875" type="cylinder" conaffinity="0" contype="0" group="1" material="table_legs_metal"/>
    </body>

    <!-- Existing authored robosuite external camera anchor. The camera itself is identity under this body. -->
    <body name="external_cam" pos="0.5170 0.3270 1.3640" quat="0.3604 0.2030 0.5000 0.7609">
      <camera name="external_camera" mode="fixed" pos="0.0 0.0 0.0" quat="1.0 0.0 0.0 0.0" fovy="42.47"/>
    </body>

    <!-- Visual-only curtains matched to current Isaac deploy scene. MuJoCo geom size is half-extent. -->
    <geom name="curtain_back" type="box" pos="-1.1 0.0 0.519" quat="1.0 0.0 0.0 0.0" size="0.005 0.8 1.0625" conaffinity="0" contype="0" group="1" material="curtain_mat"/>
    <geom name="curtain_left" type="box" pos="-0.05 0.8 0.519" quat="0.707 0.0 0.0 -0.707" size="0.005 1.05 1.0625" conaffinity="0" contype="0" group="1" material="curtain_mat"/>
    <geom name="curtain_right" type="box" pos="-0.05 -0.8 0.519" quat="0.707 0.0 0.0 -0.707" size="0.005 1.05 1.0625" conaffinity="0" contype="0" group="1" material="curtain_mat"/>

    <!-- Workspace markers for the current cube-stack/peg workspace. -->
    <site name="workspace_xmin_ymin" pos="-0.4 -0.3 0.805" size="0.008" rgba="0.0 0.2 1.0 0.65"/>
    <site name="workspace_xmin_ymax" pos="-0.4 -0.1 0.805" size="0.008" rgba="0.0 0.2 1.0 0.65"/>
    <site name="workspace_xmax_ymin" pos="-0.2 -0.3 0.805" size="0.008" rgba="0.0 0.2 1.0 0.65"/>
    <site name="workspace_xmax_ymax" pos="-0.2 -0.1 0.805" size="0.008" rgba="0.0 0.2 1.0 0.65"/>

    <body name="receptive_cube" pos="-0.3 -0.2 0.84">
      <freejoint name="receptive_cube_freejoint"/>
      <geom name="receptive_cube_collision" type="box" size="0.04 0.04 0.04" mass="0.05" friction="1 0.005 0.0001" material="receptive_cube_red"/>
    </body>

    <body name="insertive_cube" pos="-0.3 -0.2 0.94">
      <freejoint name="insertive_cube_freejoint"/>
      <geom name="insertive_cube_collision" type="box" size="0.04 0.04 0.04" mass="0.05" friction="1 0.005 0.0001" material="insertive_cube_green"/>
    </body>
  </worldbody>
</mujoco>
